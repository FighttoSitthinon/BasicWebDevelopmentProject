@model BasicWebDevelopmentProject.Models.Dto.PersonalInfoDto;
@{
    ViewData["Title"] = "Home Page";
}


<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Payment & Identity Verification</h5>
                </div>
                <div class="card-body">
                    <form id="submit_data_form" asp-action="SubmitData" method="post">
                        
                        <!-- Thai Citizen ID -->
                        <div class="form-floating mb-3">
                            <input asp-for="CitizenId" class="form-control"
                                   id="citizen_field"
                                   placeholder="X-XXXX-XXXXX-XX-X"
                                   maxlength="13"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                            <label asp-for="CitizenId"></label>
                            <span id="citizen_error_text" class="text-danger small"></span>
                            <div class="form-text">13-digit number issued by the government.</div>
                        </div>

                        <!-- Credit Card Number -->
                        <div class="form-floating mb-4">
                            <input asp-for="CreditCardNumber" class="form-control"
                                   id="creditcard_field"
                                   placeholder="0000 0000 0000 0000"
                                   maxlength="16"
                                   oninput="this.value = this.value.replace(/[^0-9]/g, '');" />
                            <label asp-for="CreditCardNumber"></label>
                            <span id="creditcard_error_text" class="text-danger small"></span>
                        </div>

                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg">Submit Information</button>
                        </div>
                        
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>



@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function ValidateCreditCard(CreditCardNumber) {

            if (CreditCardNumber.length !== 16) {
                return false;
            }

            let sum = 0;
            let alternate = false;

            for (let i = CreditCardNumber.length - 1; i >= 0; --i) {

                let d = parseInt(CreditCardNumber[i]);

                if (alternate) {

                    d *= 2;

                    if (d > 9) {
                        d -= 9;
                    }
                }

                sum += d;

                alternate = !alternate;
            }

            return sum % 10 === 0;
        }


        function ValidateCitizenId(CitizenId) {

            if (CitizenId.length !== 13) {
                return false;
            }

            let sum = 0;

            for (let i = 0; i < 12; ++i) {

                sum += (13 - i) * parseInt(CitizenId[i]);
            }

            let checkDigit = (11 - (sum % 11)) % 10;

            return checkDigit === parseInt(CitizenId[12]);
        }


        $(document).ready(function() {
            $("#citizen_field").keyup(function() {
                let citizen_text = $("#citizen_error_text")

                if(this.value.length == 0) {
                    citizen_text.text("Citizen ID is Required.")
                    return;
                }                

                if(this.value.length != 13) {
                    citizen_text.text("Citizen ID is not 13 digits long.")
                    return;
                }

                if (!ValidateCitizenId(this.value)) {
                    citizen_text.text("This Citizen ID is not Valid.")
                    return;
                }

                citizen_text.text("")
            })

            $("#creditcard_field").keyup(function() {
                let credit_text = $("#creditcard_error_text")

                if(this.value.length == 0) {
                    credit_text.text("Credit Card is Required.")
                    return;
                }                

                if(this.value.length != 16) {
                    credit_text.text("Credit Card is not 16 digits long.")
                    return;
                }

                if (!ValidateCreditCard(this.value)) {
                    credit_text.text("This Credit Card is not Valid.")
                    return;
                }

                credit_text.text("")
            })
        })

    </script>
}